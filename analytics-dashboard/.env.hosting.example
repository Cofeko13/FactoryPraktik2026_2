APP_NAME="Analytics Dashboard"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=Europe/Moscow

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=analytics_dashboard
DB_USERNAME=your_user
DB_PASSWORD=your_password

SESSION_DRIVER=database
